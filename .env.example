# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/spokestack"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Agent Builder (ongoing_agent_builder — handles all LLM routing via OpenRouter)
AGENT_BUILDER_URL="http://localhost:3001"
AGENT_BUILDER_API_KEY="your-agent-builder-api-key"

# OpenRouter (LLM inference)
OPENROUTER_API_KEY="sk-or-..."

# Redis
REDIS_URL="redis://localhost:6379"

# Telnyx (WhatsApp / Voice — Ship 2)
TELNYX_API_KEY=""
TELNYX_WEBHOOK_SECRET=""

# Nango (OAuth integration broker)
NANGO_SECRET_KEY=""
NANGO_PUBLIC_KEY=""
NANGO_HOST=""
