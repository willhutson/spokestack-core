# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/spokestack"
DIRECT_URL="postgresql://postgres:password@localhost:5432/spokestack"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# App URL (used for billing redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent Runtime (ongoing_agent_builder on Railway)
# This is the ONLY AI backend — it uses OpenRouter internally
# No OpenAI key needed in spokestack-core
AGENT_RUNTIME_URL="https://ongoingagentbuilder-production.up.railway.app"
AGENT_RUNTIME_SECRET="your-shared-secret-matching-AGENT_SECRET-in-railway"

# Agent Builder (event-driven agent execution)
AGENT_BUILDER_URL=http://localhost:4100

# Redis
REDIS_URL="redis://localhost:6379"

# Cron jobs
CRON_SECRET=

# Marketplace admin
SPOKESTACK_ADMIN_ORG_ID=

# Telnyx (WhatsApp / Voice — optional)
TELNYX_API_KEY=""
TELNYX_WEBHOOK_SECRET=""
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PUBLIC_KEY=
TELNYX_SMS_FROM=
TELNYX_WHATSAPP_FROM=

# Nango (OAuth integration broker)
NANGO_SECRET_KEY=""
NANGO_PUBLIC_KEY=""
NANGO_HOST=""

# Notifications (optional)
EMAIL_SERVICE_URL=
PUSH_SERVICE_URL=

# Vercel (for instance management)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
