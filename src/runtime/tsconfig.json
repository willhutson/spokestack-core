{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "../../dist/runtime",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@prisma/client": ["../../node_modules/.prisma/client"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
